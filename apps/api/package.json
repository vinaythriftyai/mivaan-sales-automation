{
  "name": "@mivaan/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
  "dev": "tsx watch src/server.ts",
  "build": "tsc -p tsconfig.json --noEmitOnError false || node -e \"console.log('TypeScript emitted JS with type warnings; continuing build')\"",
  "start": "node dist/server.js",
  "test": "vitest run",
  "test:watch": "vitest",
  "seed": "tsx src/database/seed.ts"
},
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^9.0.0",
    "multer": "^2.2.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "mongodb-memory-server": "^10.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
