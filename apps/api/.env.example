NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017/mivaan_sales_automation

CLIENT_ORIGIN=http://localhost:3000

JWT_SECRET=replace_this_with_a_long_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=8h

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

AUTH_PROVIDER=local
OCR_PROVIDER=mock
GST_PROVIDER=mock
MCA_PROVIDER=mock
ERP_PROVIDER=mock
NOTIFICATION_PROVIDER=mock
AI_PROVIDER=mock